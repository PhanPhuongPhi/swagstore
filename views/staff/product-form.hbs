<div class="page-container" style="max-width: 600px;">
  <div class="page-header">
    <a href="/staff/products" class="back-link">← Back to Products</a>
    <h1 class="page-title">{{#if product}}Edit Product #{{product.id}}{{else}}Add New Product{{/if}}</h1>
  </div>

  <form method="POST" action="{{#if product}}/staff/products/{{product.id}}/edit{{else}}/staff/products/new{{/if}}" class="checkout-form" style="margin-top: 2rem;">
    
    <div class="form-group">
      <label class="form-label">Name</label>
      <input type="text" name="name" class="form-input" value="{{product.name}}" required>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Price ($)</label>
        <input type="number" step="0.01" name="price" class="form-input" value="{{product.price}}" required>
      </div>
      <div class="form-group">
        <label class="form-label">Image URL</label>
        <input type="text" name="image" class="form-input" value="{{product.image}}" placeholder="/images/default.svg" required>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Category</label>
        <select name="category" class="form-input" required>
          <option value="">Select Category</option>
          {{#each categories}}
            <option value="{{name}}" {{#if (eq ../product.category name)}}selected{{/if}}>{{name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Type</label>
        <select name="type" class="form-input" required>
          <option value="">Select Type</option>
          {{#each types}}
            <option value="{{name}}" {{#if (eq ../product.type name)}}selected{{/if}}>{{name}}</option>
          {{/each}}
        </select>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Badge</label>
      <input type="text" name="badge" class="form-input" value="{{product.badge}}" placeholder="e.g. New, Bestseller, Sale">
    </div>

    <div class="form-group">
      <label class="form-label">Description</label>
      <textarea name="desc" class="form-input form-textarea" required>{{product.desc}}</textarea>
    </div>

    <button type="submit" class="btn-primary btn-full btn-large">{{#if product}}Save Changes{{else}}Add Product{{/if}}</button>
  </form>
</div>
